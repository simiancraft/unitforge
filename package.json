{
  "name": "unitforge",
  "version": "0.0.0",
  "description": "A units-of-measure library for arbitrary domains. Three free functions, three additive registries (dimensions, kits, conversions), first-class custom dimensions and packaging units, fully tree-shakeable. Not just a physics library.",
  "keywords": [
    "units",
    "unit",
    "unit-of-measure",
    "uom",
    "measurement",
    "conversion",
    "convert",
    "dimensional-analysis",
    "imperial",
    "metric",
    "si",
    "inventory",
    "packaging",
    "typescript",
    "tree-shakeable",
    "tree-shaking"
  ],
  "author": "the-simian <info@simiancraft.com>",
  "license": "MIT",
  "homepage": "https://github.com/simiancraft/unitforge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simiancraft/unitforge.git"
  },
  "bugs": {
    "url": "https://github.com/simiancraft/unitforge/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "test": "bun test",
    "check:package": "publint && attw --pack --profile esm-only",
    "check:knip": "knip",
    "demo": "bun run build && cd demo && bun run dev",
    "prepublishOnly": "bun run build && bun run check:package"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.13",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "fast-check": "^4.7.0",
    "knip": "^6.5.0",
    "publint": "^0.3.18",
    "semantic-release": "^25.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}
