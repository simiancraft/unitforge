{
  "name": "unitforge",
  "version": "1.1.1",
  "description": "Forge anything measurable. Not just physics. Three primitives (defineUnit, defineConversion, forge) compose into typed conversions for any domain you import or invent.",
  "keywords": [
    "units",
    "unit",
    "unit-of-measure",
    "uom",
    "measurement",
    "conversion",
    "convert",
    "dimensional-analysis",
    "imperial",
    "metric",
    "si",
    "inventory",
    "packaging",
    "domain",
    "currency",
    "finance",
    "game",
    "gamedev",
    "astronomy",
    "typescript",
    "tree-shakeable",
    "tree-shaking"
  ],
  "author": "the-simian <info@simiancraft.com>",
  "license": "MIT",
  "homepage": "https://github.com/simiancraft/unitforge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simiancraft/unitforge.git"
  },
  "bugs": {
    "url": "https://github.com/simiancraft/unitforge/issues"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dimensions": {
      "types": "./dist/dimensions.d.ts",
      "import": "./dist/dimensions.js"
    },
    "./kits/*": {
      "types": "./dist/kits/*/index.d.ts",
      "import": "./dist/kits/*/index.js"
    },
    "./validation": {
      "types": "./dist/lib/validation.d.ts",
      "import": "./dist/lib/validation.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo",
    "typecheck": "tsgo --noEmit && tsgo --noEmit --project tsconfig.test.json",
    "typecheck:demo": "cd demo && bunx tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "check:eslint": "cd demo && bun run lint:eslint",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "bun run build && (cd demo && bun run build) && bun run lint:fix && bun run check:eslint && bun run typecheck && bun run typecheck:demo && bun run test && bun run check:knip && bun run check:package",
    "check:package": "publint && attw --pack --profile esm-only",
    "check:knip": "knip",
    "demo": "bun run build && cd demo && bun run dev",
    "prepublishOnly": "bun run build && bun run check:package"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.13",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "knip": "^6.5.0",
    "publint": "^0.3.18",
    "semantic-release": "^25.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
